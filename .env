# Production environment — committed to git (no secrets here)
# This gets overridden by the CI step "Inject Environment Variables"
VITE_API_BASE_URL=http://titaneye.duckdns.org/api

# Local agent service — server.js runs on the Optem user's physical machine
# ALWAYS localhost regardless of environment (needed to launch GUI apps like TeamViewer/Teams)
VITE_LOCAL_SERVICE_URL=http://localhost:3001/api
