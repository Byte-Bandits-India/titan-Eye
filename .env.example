# Titan Eye+ — Environment Variables Template
# Copy this file to .env.local for local development, or set these on your deployment environment.

# Base URL for the Vite frontend to talk to the backend API server
VITE_API_BASE_URL=http://localhost:3001/api

# Local service URL for launching GUI apps (TeamViewer/Teams)
VITE_LOCAL_SERVICE_URL=http://localhost:3001/api

# A secure random secret key used to sign and verify JSON Web Tokens (JWT)
JWT_SECRET=your-secure-jwt-secret-here

# A secret key used to authenticate inbound call event webhooks
WEBHOOK_SECRET=your-webhook-secret-here

# Allowed origins for CORS (comma separated URLs)
ALLOWED_ORIGINS=http://localhost:5173
