# Titan Remote Vision Care - Production Environment Variables Template (https://titan.thebytebandits.com)

NODE_ENV=production

# Security Keys
JWT_SECRET=your-production-jwt-secret-key-here
WEBHOOK_SECRET=your-production-webhook-secret-here

# CORS & Domain Settings
ALLOWED_ORIGINS=https://titan.thebytebandits.com
FRONTEND_URL=https://titan.thebytebandits.com
VITE_API_BASE_URL=https://titan.thebytebandits.com/api
VITE_LOCAL_SERVICE_URL=https://titan.thebytebandits.com/api

# Initial Seed Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SetAStrongPassword123!

# Microsoft Entra ID (Azure AD) SSO (Optional - leave blank if unused)
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_CLIENT_ID=your-client-id-here
ENTRA_CLIENT_SECRET=your-client-secret-here
ENTRA_REDIRECT_URI=https://titan.thebytebandits.com/api/auth/microsoft/callback
